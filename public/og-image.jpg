<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0a0a0a"/>
      <stop offset="100%" style="stop-color:#111827"/>
    </linearGradient>
    <linearGradient id="text-grad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#f59e0b"/>
      <stop offset="100%" style="stop-color:#3b82f6"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <rect x="0" y="0" width="1200" height="4" fill="url(#text-grad)"/>
  <circle cx="1050" cy="150" r="200" fill="#3b82f6" opacity="0.06"/>
  <circle cx="150" cy="480" r="180" fill="#f59e0b" opacity="0.06"/>
  <text x="600" y="240" font-family="system-ui, -apple-system, sans-serif" font-size="88" font-weight="700" text-anchor="middle" fill="url(#text-grad)">DON SEO</text>
  <text x="600" y="330" font-family="system-ui, -apple-system, sans-serif" font-size="32" font-weight="400" text-anchor="middle" fill="#9ca3af">Professional SEO Services</text>
  <text x="600" y="390" font-family="system-ui, -apple-system, sans-serif" font-size="24" font-weight="400" text-anchor="middle" fill="#6b7280">Technical SEO · Content Strategy · Link Building</text>
  <rect x="480" y="440" width="240" height="56" rx="28" fill="#f59e0b" opacity="0.15"/>
  <rect x="480" y="440" width="240" height="56" rx="28" fill="none" stroke="#f59e0b" stroke-width="1.5" opacity="0.4"/>
  <text x="600" y="475" font-family="system-ui, -apple-system, sans-serif" font-size="20" font-weight="600" text-anchor="middle" fill="#f59e0b">don-seo.com</text>
</svg>
